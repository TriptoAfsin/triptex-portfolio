ingCount":0,"source":null},{"filePath":"59","messages":"60","errorCount":0,"warningCount":14,"fixableErrorCount":0,"fixableWarningCount":0,"source":null},{"filePath":"61","messages":"62","errorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":"36"},{"filePath":"63","messages":"64","errorCount":0,"warningCount":1,"fixableErrorCount":0,"fixableWarningCount":0,"source":"65","usedDeprecatedRules":"36"},{"filePath":"66","messages":"67","errorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0},{"filePath":"68","messages":"69","errorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0},"V:\\Webdev\\React Projects\\triptex-portfolio\\src\\index.js",[],["70","71"],"V:\\Webdev\\React Projects\\triptex-portfolio\\src\\App.js",["72"],"import React from 'react'\n\nimport { HashRouter as Router, Switch, Route } from 'react-router-dom';\nimport Footer from './components/layout/Footer';\nimport Navbar from './components/layout/Navbar';\nimport Contact from './pages/Contact';\nimport CV from './pages/CV';\nimport FrontPage from './pages/FrontPage';\nimport Projects from './pages/Projects';\n\n\n\nfunction App() {\n  return (\n    <Router>\n      <Navbar></Navbar>\n      \n     <Switch>\n        <Route path='/' exact component={FrontPage}></Route>\n        <Route path='/cv' exact component={CV}></Route>\n        <Route path='/projects' exact component={Projects}></Route>\n        <Route path='/contact' exact component={Contact}></Route>\n     </Switch>\n    </Router>\n  );\n}\n\nexport default App;\n","V:\\Webdev\\React Projects\\triptex-portfolio\\src\\reportWebVitals.js",[],"V:\\Webdev\\React Projects\\triptex-portfolio\\src\\pages\\CV.js",[],"V:\\Webdev\\React Projects\\triptex-portfolio\\src\\pages\\FrontPage.js",["73","74","75","76"],"V:\\Webdev\\React Projects\\triptex-portfolio\\src\\pages\\Contact.js",[],"V:\\Webdev\\React Projects\\triptex-portfolio\\src\\components\\layout\\Navbar.js",[],"V:\\Webdev\\React Projects\\triptex-portfolio\\src\\pages\\Projects.js",["77","78","79","80","81"],"import React, {useState, useEffect} from 'react'\r\nimport DataProvider from '../components/DataHandler/DataProvider'\r\nimport '../components/css/loader.css'\r\n\r\n\r\nfunction Projects() {\r\n\r\n    const [loading, setLoading] = useState(true)\r\n    const [query, setQuery] = useState('')\r\n    const[match, setMatch] = useState('')\r\n\r\n    \r\n\r\n    const repoData = DataProvider()\r\n    console.log(repoData)\r\n\r\n    useEffect(\r\n        () => {\r\n            if(repoData !== null){\r\n                setLoading(false)\r\n                console.log(\"setLoading false now\")\r\n                searchQuery(repoData)\r\n                console.log(query)\r\n            }\r\n        }, [repoData, query]\r\n    )\r\n\r\n\r\n    //regex\r\n    const matchList = document.getElementById(\"card-container\");\r\n\r\n    const searchQuery = (libs) => {\r\n        let matches = libs.filter(lib =>{\r\n            const regex = new RegExp(`${query}`, 'gi'); // ^: will search for which resuls starts with , gi:case insensitive search,RegExp: Regular Expression\r\n            return lib.name.match(regex) || lib.about.match(regex) || lib.terms.match(regex)\r\n        });\r\n        if(query.length > 0){\r\n            outputHtml(matches);\r\n            setMatch(matches.length)\r\n            console.log(matches)\r\n        }   \r\n    }\r\n\r\n    const outputHtml = matches =>{\r\n        if(matches.length > 0){\r\n            const html = matches.map(match => `\r\n            <div class=\"card greyGradient floatIn\" key={element.link}>\r\n                    <p class=\"card-title txt-xxl\">${match.name}</p>\r\n                    <p class=\"card-txt\">${match.about}</p>\r\n                    <a class=\"card-btn pad2 right blue\" href=${match.link} target=\"_blank\">Learn more...</a>\r\n                </div>\r\n            `).join('');\r\n\r\n        console.log(html);\r\n        matchList.innerHTML = html;\r\n        }\r\n        else {\r\n            try {\r\n                matchList.innerHTML = `<h1>No results</h1>`;\r\n            } catch (error) {\r\n                return\r\n            } \r\n        }\r\n    };\r\n\r\n\r\n    if(loading){\r\n        return (\r\n            <React.Fragment>\r\n                <div className=\"center-self mt4\">\r\n                    <a><div className=\"lds-roller\"><div></div><div></div><div></div><div></div><div></div><div></div><div></div><div></div></div></a>\r\n                </div>\r\n               \r\n            </React.Fragment>\r\n        )\r\n    }\r\n    else{\r\n        return(\r\n            <React.Fragment>\r\n               <div>\r\n                   <div className=\"center-self mb4 mt2 pad2\">\r\n                        <input className=\"rounded shadow txt-lg pad10\" placeholder=\"Search...\" onChange={e => setQuery(e.target.value)} value={query}></input>\r\n                   </div>\r\n                    <div className=\"card-container\" id=\"card-container\">\r\n                        {\r\n                            repoData.map(element => {\r\n                                return (\r\n  \r\n                                    <div className={\"card floatIn greyGradient\"} key={element.link}>\r\n                                        <p className=\"card-title txt-xxl\">{element.name}</p>\r\n                                        <p className=\"card-txt\">{element.about}</p>\r\n                                        <a className=\"card-btn pad2 right blue\" href={element.link} target=\"_blank\">Learn more...</a>\r\n                                    </div>\r\n                                )\r\n                            })\r\n                        }\r\n                    </div>\r\n                </div> \r\n                <div className=\"row pad4 center-self mt4\">\r\n                        <a href=\"https://github.com/TriptoAfsin\" className=\"button center-self txt-lg bold blueGradient\" target=\"_blank\">👉 Github</a>\r\n                </div>\r\n        </React.Fragment>\r\n        )\r\n    }\r\n}\r\n\r\nexport default Projects\r\n","V:\\Webdev\\React Projects\\triptex-portfolio\\src\\components\\Sections\\PersonalSec.js",[],"V:\\Webdev\\React Projects\\triptex-portfolio\\src\\components\\Sections\\EducationSec.js",[],"V:\\Webdev\\React Projects\\triptex-portfolio\\src\\components\\Sections\\SocialSection.js",["82"],"V:\\Webdev\\React Projects\\triptex-portfolio\\src\\components\\Sections\\Skills.js",["83","84","85","86","87","88","89","90","91","92","93","94","95","96"],"V:\\Webdev\\React Projects\\triptex-portfolio\\src\\components\\layout\\Footer.js",[],"V:\\Webdev\\React Projects\\triptex-portfolio\\src\\components\\DataHandler\\DataProvider.js",["97"],"import {useEffect, useState} from 'react'\r\nimport axios from 'axios'\r\n\r\n\r\n//kinda similar article: https://dev.to/rikurouvila/clean-and-reusable-data-fetching-in-react-components-165\r\n//more on axios: https://blog.logrocket.com/how-to-make-http-requests-like-a-pro-with-axios/\r\n\r\nfunction DataProvider() {\r\n\r\n    console.log(\"DataProvider Called\")\r\n    const[dbData, setDbData] = useState(null)\r\n    //const [loading, setLoading] = useState(true)\r\n    const url = \"https://triptoafsin.github.io/API-Host/myProjects.json\"\r\n\r\n     //pulling data \r\n\r\n     useEffect(\r\n        () => {\r\n            axios.get(url)\r\n        .then(res => {\r\n        //setLoading(false);\r\n        setDbData(res.data);\r\n        console.log(\"Axios called\");\r\n        return dbData;\r\n    }).catch(err => console.log(err));\r\n\r\n        }, [url]\r\n)\r\n    return dbData;\r\n}\r\n\r\nexport default DataProvider\r\n","V:\\Webdev\\React Projects\\triptex-portfolio\\src\\components\\Sections\\MobileSkills.js",[],"V:\\Webdev\\React Projects\\triptex-portfolio\\src\\components\\Hooks\\ResizeHandler.js",[],{"ruleId":"98","replacedBy":"99"},{"ruleI