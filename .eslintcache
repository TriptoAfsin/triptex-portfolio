,{"filePath":"60","messages":"61","errorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0},{"filePath":"62","messages":"63","errorCount":0,"warningCount":2,"fixableErrorCount":0,"fixableWarningCount":0,"source":null},{"filePath":"64","messages":"65","errorCount":0,"warningCount":1,"fixableErrorCount":0,"fixableWarningCount":0,"source":"66","usedDeprecatedRules":"36"},{"filePath":"67","messages":"68","errorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0},{"filePath":"69","messages":"70","errorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":"36"},"V:\\Webdev\\React Projects\\triptex-portfolio\\src\\index.js",[],["71","72"],"V:\\Webdev\\React Projects\\triptex-portfolio\\src\\App.js",["73"],"import React from 'react'\n\nimport { HashRouter as Router, Switch, Route } from 'react-router-dom';\nimport Footer from './components/layout/Footer';\nimport Navbar from './components/layout/Navbar';\nimport Contact from './pages/Contact';\nimport CV from './pages/CV';\nimport FrontPage from './pages/FrontPage';\nimport Projects from './pages/Projects';\n\n\n\nfunction App() {\n  return (\n    <Router>\n      <Navbar></Navbar>\n      \n     <Switch>\n        <Route path='/' exact component={FrontPage}></Route>\n        <Route path='/cv' exact component={CV}></Route>\n        <Route path='/projects' exact component={Projects}></Route>\n        <Route path='/contact' exact component={Contact}></Route>\n     </Switch>\n    </Router>\n  );\n}\n\nexport default App;\n","V:\\Webdev\\React Projects\\triptex-portfolio\\src\\reportWebVitals.js",[],"V:\\Webdev\\React Projects\\triptex-portfolio\\src\\pages\\CV.js",[],"V:\\Webdev\\React Projects\\triptex-portfolio\\src\\pages\\FrontPage.js",["74","75","76","77"],"import React from 'react'\r\nimport { useState, useEffect } from 'react';\r\n\r\nimport Typewriter from 'typewriter-effect'; // more: https://www.npmjs.com/package/typewriter-effect\r\nimport EducationSec from '../components/Sections/EducationSec';\r\nimport PersonalSec from '../components/Sections/PersonalSec';\r\nimport Skills from '../components/Sections/Skills';\r\nimport SocialSection from '../components/Sections/SocialSection';\r\n\r\nimport  {Link} from 'react-router-dom'\r\nimport Footer from '../components/layout/Footer';\r\nimport MobileSkills from '../components/Sections/MobileSkills';\r\n\r\nimport useWindowDimensions from '../components/Hooks/ResizeHandler'\r\n\r\n\r\n\r\n\r\nconst strings = [\"a Freelance Webdeveloper\", \"an Engineering Student\", \"a Learner\", \"a Teacher\"];\r\n\r\n\r\n\r\n\r\n\r\n\r\nfunction FrontPage() {\r\n    const { height, width } =  useWindowDimensions();\r\n\r\n    return (\r\n        <React.Fragment>\r\n            <div className=\"row mt4 center-self\">\r\n                <div className=\"column float-left center-self\">\r\n                    <a><img src=\"./imgs/dev.webp\" className=\"rounded-img shadow\" alt=\"TriptoAfsin\" width=\"180px\" height=\"180px\"></img></a>\r\n                </div>\r\n                <div className=\"column float-right pad4\">\r\n                    <p className=\"txt-xxl left-txt bold center-txt\">Afshin Nahian Tripto</p>\r\n\r\n                    <div className=\"txt-xl\">\r\n                        <Typewriter\r\n                            onInit={(typewriter) => {\r\n                                typewriter.typeString(`I'm ${strings[0]}`)\r\n                                    .callFunction(() => {\r\n                                        console.log('String typed out!');\r\n                                    })\r\n                                    .pauseFor(2000)\r\n                                    .deleteChars(strings[0].length)\r\n                                    .typeString(`${strings[1]}`)\r\n                                    .pauseFor(2000)\r\n                                    .deleteChars(strings[1].length)\r\n                                    .typeString(`${strings[2]}`)\r\n                                    .pauseFor(2000)\r\n                                    .deleteChars(strings[2].length)\r\n                                    .deleteAll()\r\n                                    .typeString(`Webdeveloper || Student || Learner`)\r\n                                    .callFunction(() => {\r\n                                        console.log(\"Typing Done !\")\r\n                                    })\r\n                                    .start();\r\n                            }}\r\n                        />\r\n                    </div>\r\n                    <div className=\"hide-on-mobile\">\r\n                        <SocialSection></SocialSection>\r\n                    </div> \r\n                </div>\r\n            </div>\r\n            <div className=\"center-self mt5 mb5\">\r\n                <PersonalSec></PersonalSec>\r\n                <EducationSec></EducationSec>\r\n            </div>\r\n            <div className=\"row\">\r\n            <div className=\"width50 mb4\">\r\n                <div className=\"\">\r\n                    {width >= 820 ? <Skills></Skills> : <MobileSkills></MobileSkills>}\r\n                </div>\r\n            </div>\r\n            <div className=\"width50 mb4\">\r\n             <div className=\"column\">\r\n                <div className=\"center-self mt4 pad4 orange\">\r\n                    <p className=\"txt-xxxl bold\">Projects</p>\r\n                </div>\r\n                <div class=\"column pad4\">\r\n                    <div class=\"card greyGradient\">\r\n                        <p class=\"card-title txt-xxl\">Cloud lib</p>\r\n                        <p class=\"card-txt\">\r\n                            Cloud lib is an open collaborative project for better educational content distribution\r\n                        </p>\r\n                        <a className=\"card-btn pad2 right\" href=\"https://triptoafsin.github.io/Cloud-Lib-React/#/\">Learn more</a>\r\n                    </div>\r\n                    <div class=\"card greyGradient\">\r\n                        <p class=\"card-title txt-xxl\">BUTEX NoteBOT</p>\r\n                        <p class=\"card-txt\">\r\n                        This is a messenger chatbot made for BUTEX(Bangladesh University of Textiles) to \r\n                        deliver study materials 24x7\r\n                        </p>\r\n                        <a className=\"card-btn pad2 right\" href=\"https://github.com/TriptoAfsin/notebot-engine-v1\">Learn more</a>\r\n                    </div>\r\n                    <div class=\"card greyGradient\">\r\n                        <p class=\"card-title txt-xxl\">CountKoto-Android-App</p>\r\n                        <p class=\"card-txt\">\r\n                        Versatile Textile Count Calculation Tool\r\n                        </p>\r\n                        <a className=\"card-btn pad2 right\" href=\"https://play.google.com/store/apps/details?id=newcampusa.newproject.countkoto\">Learn more</a>\r\n                    </div>\r\n                    <div className=\"row pad4\">\r\n                        <Link to=\"/projects\" className=\"button center-self txt-lg bold blueGradient\">Other Projects 👉</Link>\r\n                    </div>\r\n                </div>\r\n            </div>\r\n            </div>         \r\n            </div>\r\n            <Footer></Footer>\r\n           \r\n        </React.Fragment>\r\n    )\r\n}\r\n\r\nexport default FrontPage\r\n","V:\\Webdev\\React Projects\\triptex-portfolio\\src\\pages\\Contact.js",[],"V:\\Webdev\\React Projects\\triptex-portfolio\\src\\components\\layout\\Navbar.js",[],"V:\\Webdev\\React Projects\\triptex-portfolio\\src\\pages\\Projects.js",["78","79","80","81","82"],"import React, {useState, useEffect} from 'react'\r\nimport DataProvider from '../components/DataHandler/DataProvider'\r\nimport '../components/css/loader.css'\r\n\r\n\r\nfunction Projects() {\r\n\r\n    const [loading, setLoading] = useState(true)\r\n    const [query, setQuery] = useState('')\r\n    const[match, setMatch] = useState('')\r\n\r\n    \r\n\r\n    const repoData = DataProvider()\r\n    console.log(repoData)\r\n\r\n    useEffect(\r\n        () => {\r\n            if(repoData !== null){\r\n                setLoading(false)\r\n                console.log(\"setLoading false now\")\r\n                searchQuery(repoData)\r\n                console.log(query)\r\n            }\r\n        }, [repoData, query]\r\n    )\r\n\r\n\r\n    //regex\r\n    const matchList = document.getElementById(\"card-container\");\r\n\r\n    const searchQuery = (libs) => {\r\n        let matches = libs.filter(lib =>{\r\n            const regex = new RegExp(`${query}`, 'gi'); // ^: will search for which resuls starts with , gi:case insensitive search,RegExp: Regular Expression\r\n            return lib.name.match(regex) || lib.about.match(regex) || lib.terms.match(regex)\r\n        });\r\n        if(query.length > 0){\r\n            outputHtml(matches);\r\n            setMatch(matches.length)\r\n            console.log(matches)\r\n        }   \r\n    }\r\n\r\n    const outputHtml = matches =>{\r\n        if(matches.length > 0){\r\n            const html = matches.map(match => `\r\n            <div class=\"card greyGradient floatIn\" key={element.link}>\r\n                    <p class=\"card-title txt-xxl\">${match.name}</p>\r\n                    <p class=\"card-txt\">${match.about}</p>\r\n                    <a class=\"card-btn pad2 right blue\" href=${match.link} target=\"_blank\">Learn more...</a>\r\n                </div>\r\n            `).join('');\r\n\r\n        console.log(html);\r\n        matchList.innerHTML = html;\r\n        }\r\n        else {\r\n            try {\r\n                matchList.innerHTML = `<h1>No results</h1>`;\r\n            } catch (error) {\r\n                return\r\n            } \r\n        }\r\n    };\r\n\r\n\r\n    if(loading){\r\n        return (\r\n            <React.Fragment>\r\n                <div className=\"center-self mt4\">\r\n                    <a><div className=\"lds-roller\"><div></div><div></div><div></div><div></div><div></div><div></div><div></div><div></div></div></a>\r\n                </div>\r\n               \r\n            </React.Fragment>\r\n        )\r\n    }\r\n    else{\r\n        return(\r\n            <React.Fragment>\r\n               <div>\r\n                   <div className=\"center-self mb4 mt2 pad2\">\r\n                        <input className=\"rounded shadow txt-lg pad10\" placeholder=\"Search...\" onChange={e => setQuery(e.target.value)} value={query}></input>\r\n                   </div>\r\n                    <div className=\"card-container\" id=\"card-container\">\r\n                        {\r\n                            repoData.map(element => {\r\n                                return (\r\n  \r\n                                    <div className={\"card floatIn greyGradient\"} key={element.link}>\r\n                                        <p className=\"card-title txt-xxl\">{element.name}</p>\r\n                                        <p className=\"card-txt\">{element.about}</p>\r\n                                        <a className=\"card-btn pad2 right blue\" href={element.link} target=\"_blank\">Learn more...</a>\r\n                                    </div>\r\n                                )\r\n                            })\r\n                        }\r\n                    </div>\r\n                </div> \r\n                <div className=\"row pad4 center-self mt4\">\r\n                        <a href=\"https://github.com/TriptoAfsin\" className=\"button center-self txt-lg bold blueGradient\" target=\"_blank\">👉 Github</a>\r\n                </div>\r\n        </React.Fragment>\r\n        )\r\n    }\r\n}\r\n\r\nexport default Projects\r\n","V:\\Webdev\\React Projects\\triptex-portfolio\\src\\components\\Sections\\PersonalSec.js",[],"V:\\Webdev\\React Projects\\triptex-portfolio\\src\\components\\Sections\\EducationSec.js",[],"V:\\Webdev\\React Projects\\triptex-portfolio\\src\\components\\Sections\\SocialSection.js",["83"],"V:\\Webdev\\React Projects\\triptex-portfolio\\src\\components\\Sections\\Skills.js",[],"V:\\Webdev\\React Projects\\triptex-portfolio\\src\\components\\layout\\Footer.js",["84","85"],"V:\\Webdev\\React Projects\\triptex-portfolio\\src\\components\\DataHandler\\DataProvider.js",["86"],"import {useEffect, useState} from 'react'\r\nimport axios from 'axios'\r\n\r\n\r\n//kinda similar article: https://dev.to/rikurouvila/clean-and-reusable-data-fetching-in-react-components-165\r\n//more on axios: https://blog.logrocket.com/how-to-make-http-requests-like-a-pro-with-axios/\r\n\r\nfunction DataProvider() {\r\n\r\n    console.log(\"DataProvider Called\")\r\n    const[dbData, setDbData] = useState(null)\r\n    //const [loading, setLoading] = useState(true)\r\n    const url = \"https://triptoafsin.github.io/API-Host/myProjects.json\"\r\n\r\n     //pulling data \r\n\r\n     useEffect(\r\n        () => {\r\n            axios.get(url)\r\n        .then(res => {\r\n        //setLoading(false);\r\n        setDbData(res.data);\r\n        console.log(\"Axios called\");\r\n        return dbData;\r\n    }).catch(err => console.log(err));\r\n\r\n        }, [url]\r\n)\r\n    return dbData;\r\n}\r\n\r\nexport default DataProvider\r\n","V:\\Webdev\\React Projects\\triptex-portfolio\\src\\components\\Sections\\MobileSkills.js",[],"V:\\Webdev\\React Projects\\triptex-portfolio\\src\\components\\Hooks\\ResizeHandler.js",[],{"ruleId":"87","replacedBy":"88"},{"ruleId":"89","replacedBy":"90"},{"ruleId":"91","severity":1,"message":"92","line":4,"column":8,"nodeType":"93","messageId":"94","endLine":4,"endColumn":14},{"ruleId":"91","severity":1,"message":"95","line":2,"column":10,"nodeType":"93","messageId":"94","endLine":2,"endColumn":18},{"ruleId":"91","severity":1,"message":"96","line":2,"column":20,"nodeType":"93","messageId":"94","e